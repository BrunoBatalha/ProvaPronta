{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "outDir": ".test-dist",
    "rootDir": "."
  },
  "include": ["src/lib/**/*.ts", "src/types/**/*.ts", "tests/**/*.ts"]
}
